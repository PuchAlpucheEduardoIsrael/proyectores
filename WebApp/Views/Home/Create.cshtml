@model Proyector
@{
    ViewData["Title"] = "Nuevo Proyector";
}

<div class="container">
    <h1 class="display-5 mb-3">Nuevo Proyector</h1>
    <div class="row">
        <form>
            <div class="form-group mb-3">
                <label class="form-label" asp-for="Id">Número de Proyector:</label>
                <input type="number" class="form-control" asp-for="Id" id="Id" />
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="Marca">Marca del Proyector:</label>
                <input type="text" class="form-control" asp-for="Marca" id="Marca"/>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="Modelo">Modelo:</label>
                <input type="text" class="form-control" asp-for="Modelo" id="Modelo"/>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="NumeroDeSerie">Número de Serie:</label>
                <input type="text" class="form-control" asp-for="NumeroDeSerie" id="NumeroDeSerie" />
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="FechaDeAlta">Fecha de Alta:</label>
                <input type="date" class="form-control" asp-for="FechaDeAlta" id="FechaDeAlta" />
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="Situacion">Situación del Proyector</label>
                <select class="form-select" asp-for="Situacion" id="Situacion">
                    <option value="1">Bueno</option>
                    <option value="2">Regular</option>
                    <option value="3">Malo</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <button type="button" class="btn btn-secondary">Cancelar</button>
            </div>
        </form>
    </div>
</div>
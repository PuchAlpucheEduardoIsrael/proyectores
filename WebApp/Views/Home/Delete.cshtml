@using WebApp.ViewModels;
@model Proyector;
@{
    ViewData["Title"] = "Eliminar Proyector";
}


<div class="container">
    <h3 class="display-6">¿Desea eliminar este proyecto?</h3>
</div>

    <div class="bg-body-secondary p-3 mb-5 fs-5">
        <h4 class="mb-3">Información del Proyecto #@Model.Id</h4>
        <div class="row">
            <div class="form-group mb-3 col">
                <label class="form-label">Marca:</label>
                <label class="form-label">@Model.Marca</label>
            </div>

            <div class="form-group mb-3 col">
                <label class="form-label">Modelo:</label>
                <label class="form-label">@Model.Modelo</label>
            </div>

            <div class="form-group mb-3 col">
                <label class="form-label"># De Serie:</label>
                <label class="form-label">@Model.NumeroDeSerie</label>
            </div>
        </div>

        <div class="row">
            <div class="form-group col">
                <label class="form-label">Fecha de Alta:</label>
                <label class="form-label">@Model.FechaDeAlta</label>
            </div>

            <div class="form-group col">
                <label class="form-label">Fecha de Baja:</label>
                <label class="form-label">@Model.FechaDeBaja</label>
            </div>

            <div class="form-group col" ">
                <label class="form-label">Situación:</label>
                <label class="form-label">@Model.Situacion</label>
            </div>
        </div>
    </div>

    <form method="post" asp-controller="Home" asp-action="Delete">
        <div class="d-flex justify-content-end">
            <a class="btn btn-primary mx-3" asp-controller="Home" asp-action="Index">Cancelar </a>
            <button type="submit" class="btn btn-danger mx-3" asp-route-id="@Model.Id">Eliminar</button>
        </div>
    </form>



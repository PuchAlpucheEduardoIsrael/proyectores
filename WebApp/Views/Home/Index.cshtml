@model IEnumerable<Proyector>;
@{
    ViewData["Title"] = "Inicio";
}
@if (Model is not null)
{
    <div class="container">
        <h1>Proyectores</h1>
        <h3>Información de los proyectores registrados</h3>
           @if (Model.Any<Proyector>()) 
@*         @if (Model.Count<Proyector>() > 0) *@
        {
            <table>
                <thead>
                    <tr>
                        <th># proyector</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th># de Serie</th>
                        <th>Situación</th>
                        <th>Fecha de Alta</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Proyector proyector in Model)
                    {
                        <tr>
                            <td>@proyector.Id</td>
                            <td>@proyector.Marca</td>
                            <td>@proyector.Modelo</td>
                            <td>@proyector.NumeroDeSerie</td>
                            <td>@proyector.Situacion</td>
                            <td>@proyector.FechaDeAlta.ToShortDateString()</td>
                        </tr>
                    }

                </tbody>
            </table>
        }
        else
        {
            <hd>Aún no hay proyectores registrados</hd>
        }
    </div>  
}

